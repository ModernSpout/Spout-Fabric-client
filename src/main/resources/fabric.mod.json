{
  "schemaVersion": 1,
  "id": "fiddle-client",
  "version": "${version}",
  "name": "Fiddle client",
  "description": "Automatically downloads and install custom blocks and items when joining Fiddle servers",
  "authors": [
    "Martijn Muijsers",
    "Other FiddleMC contributors"
  ],
  "contact": {
    "homepage": "https://fiddlemc.org/",
    "sources": "https://github.com/FiddleMC/Fiddle-mod"
  },
  "license": "Mostly GPL-3.0, see LICENSE.md for details",
  "icon": "assets/fiddle/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "org.fiddlemc.fiddle.client.Fiddle"
    ],
    "client": [
      "org.fiddlemc.fiddle.client.FiddleClient"
    ]
  },
  "mixins": [
    "fiddle-client.mixins.json",
    {
      "config": "fiddle-client.client.mixins.json",
      "environment": "client"
    },
    {
      "config": "fiddle-client.client.clientview.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
